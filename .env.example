# ── Telegram ──
TELEGRAM_BOT_TOKEN=xxxx:yyyy
TELEGRAM_CHAT_ID=-100xxxxx

# ── Scraper Servisleri ──
FIRECRAWL_API_KEY=fc-xxxxx
CF_WORKER_URL=https://vatan-scraper.xxx.workers.dev

# ── Proxy (virgülle ayır) ──
PROXY_LIST=http://user:pass@proxy1:port,http://user:pass@proxy2:port

# ── E-posta ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=app-password
EMAIL_TO=recipient@example.com

# ── Fiyat Ayarları ──
PRICE_DROP_THRESHOLD=0.05

# ── Scraper Seçimi: crawl4ai, firecrawl, worker, requests ──
PRIMARY_SCRAPER=requests
